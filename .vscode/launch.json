{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug NUCLEO-G431KB via ST-LINK",
      "type": "cortex-debug",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/nucleo-debug/finger_firmware",
      "device": "STM32G431KB",
      "interface": "swd",
      "servertype": "stlink",
      "serverpath": "${workspaceFolder}/tools/ST-LINK_gdbserver",
      "runToEntryPoint": "main",
      "preLaunchTask": "Build nucleo-debug",
      "liveWatch": {
        "enabled": true,
        "samplesPerSecond": 4
      },
      "showDevDebugOutput": "none"
    }
  ]
}
